@model LocalServicesBooking.Models.ViewModels.VerifyEmailViewModel

@{
    ViewData["Title"] = "Verify Email";
    Layout = "_Layout";
}

<div class="auth-container">
    <div class="auth-card animate-scale-in text-center">
        <div class="mb-4">
            <div class="d-inline-flex align-items-center justify-content-center rounded-circle animate-pulse" 
                 style="width: 80px; height: 80px; background: var(--gradient-primary);">
                <i class="bi bi-envelope-check fs-1 text-white"></i>
            </div>
        </div>
        
        <h1 class="auth-title">Verify Your Email</h1>
        <p class="auth-subtitle">
            We've sent a verification code to<br />
            <strong class="text-primary">@Model.Email</strong>
        </p>
        
        <form asp-action="VerifyEmail" method="post" class="mt-4">
            <input type="hidden" asp-for="Email" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" role="alert"></div>
            
            <div class="mb-4">
                <label asp-for="Code" class="form-label">Enter Verification Code</label>
                <div class="otp-input-container d-flex gap-2 justify-content-center" data-otp-target="#fullCode">
                    <input type="text" maxlength="1" class="form-control text-center fs-4 fw-bold" style="width: 50px; height: 60px;" />
                    <input type="text" maxlength="1" class="form-control text-center fs-4 fw-bold" style="width: 50px; height: 60px;" />
                    <input type="text" maxlength="1" class="form-control text-center fs-4 fw-bold" style="width: 50px; height: 60px;" />
                    <input type="text" maxlength="1" class="form-control text-center fs-4 fw-bold" style="width: 50px; height: 60px;" />
                    <input type="text" maxlength="1" class="form-control text-center fs-4 fw-bold" style="width: 50px; height: 60px;" />
                    <input type="text" maxlength="1" class="form-control text-center fs-4 fw-bold" style="width: 50px; height: 60px;" />
                </div>
                <input type="hidden" asp-for="Code" id="fullCode" />
                <span asp-validation-for="Code" class="text-danger small"></span>
            </div>
            
            <button type="submit" class="btn btn-primary w-100 btn-lg mb-3">
                <i class="bi bi-check-circle me-2"></i> Verify Email
            </button>
        </form>
        
        <p class="text-secondary mb-3">
            Didn't receive the code?
        </p>
        <button class="btn btn-outline-primary" id="resendBtn" disabled>
            <i class="bi bi-arrow-clockwise me-2"></i> Resend Code (<span id="countdown">60</span>s)
        </button>
        
        <div class="mt-4 pt-4" style="border-top: 1px solid var(--border-color);">
            <a asp-controller="Account" asp-action="Register" class="text-secondary text-decoration-none">
                <i class="bi bi-arrow-left me-1"></i> Back to Registration
            </a>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Countdown timer
            let timeLeft = 60;
            const countdownEl = document.getElementById('countdown');
            const resendBtn = document.getElementById('resendBtn');
            
            const timer = setInterval(() => {
                timeLeft--;
                countdownEl.textContent = timeLeft;
                
                if (timeLeft <= 0) {
                    clearInterval(timer);
                    resendBtn.disabled = false;
                    resendBtn.innerHTML = '<i class="bi bi-arrow-clockwise me-2"></i> Resend Code';
                }
            }, 1000);
        });
    </script>
}
