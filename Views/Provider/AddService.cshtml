@model LocalServicesBooking.Models.ViewModels.AddServiceViewModel

@{
    ViewData["Title"] = "Add Service";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h4>Add New Service</h4>
                </div>
                <div class="card-body">
                    <form asp-action="AddService" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="CategoryId" class="form-label"></label>
                            <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories">
                                <option value="">-- Select Category --</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ServiceName" class="form-label"></label>
                            <input asp-for="ServiceName" class="form-control" />
                            <span asp-validation-for="ServiceName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label"></label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="BasePrice" class="form-label"></label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input asp-for="BasePrice" class="form-control" />
                                </div>
                                <span asp-validation-for="BasePrice" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="PriceUnit" class="form-label"></label>
                                <select asp-for="PriceUnit" class="form-select">
                                    <option value="hour">Per Hour</option>
                                    <option value="job">Per Job</option>
                                    <option value="sqft">Per Sq Ft</option>
                                </select>
                                <span asp-validation-for="PriceUnit" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DurationMinutes" class="form-label"></label>
                            <input asp-for="DurationMinutes" class="form-control" type="number" placeholder="Minutes (optional)" />
                            <span asp-validation-for="DurationMinutes" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">Add Service</button>
                            <a asp-action="ManageServices" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
