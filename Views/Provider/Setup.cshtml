@model LocalServicesBooking.Models.ViewModels.ProviderSetupViewModel

@{
    ViewData["Title"] = "Provider Setup";
}

<section class="py-5" style="background: var(--gradient-hero); min-height: 100vh;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="card card-glass animate-scale-in">
                    <div class="card-body p-4 p-md-5">
                        <div class="text-center mb-4">
                            <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3" 
                                 style="width: 70px; height: 70px; background: var(--gradient-primary);">
                                <i class="bi bi-briefcase fs-3 text-white"></i>
                            </div>
                            <h2 class="mb-2">Complete Your Provider Profile</h2>
                            <p class="text-secondary">Tell us about your business so customers can find you</p>
                        </div>
                        
                        <!-- Progress Steps -->
                        <div class="d-flex justify-content-center gap-3 mb-4">
                            <div class="d-flex align-items-center gap-2">
                                <span class="rounded-circle d-flex align-items-center justify-content-center" 
                                      style="width: 30px; height: 30px; background: var(--gradient-primary); color: white; font-size: 0.8rem;">
                                    <i class="bi bi-check"></i>
                                </span>
                                <span class="small">Account</span>
                            </div>
                            <div style="width: 30px; height: 2px; background: var(--primary); align-self: center;"></div>
                            <div class="d-flex align-items-center gap-2">
                                <span class="rounded-circle d-flex align-items-center justify-content-center" 
                                      style="width: 30px; height: 30px; background: var(--gradient-primary); color: white; font-size: 0.8rem;">
                                    2
                                </span>
                                <span class="small fw-semibold">Profile</span>
                            </div>
                            <div style="width: 30px; height: 2px; background: var(--border-color); align-self: center;"></div>
                            <div class="d-flex align-items-center gap-2">
                                <span class="rounded-circle d-flex align-items-center justify-content-center" 
                                      style="width: 30px; height: 30px; background: var(--border-color); color: var(--text-muted); font-size: 0.8rem;">
                                    3
                                </span>
                                <span class="small text-muted">Services</span>
                            </div>
                        </div>
                        
                        <form asp-action="Setup" method="post" data-validate>
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>
                            
                            <div class="mb-4">
                                <label asp-for="BusinessName" class="form-label">Business Name</label>
                                <div class="position-relative">
                                    <input asp-for="BusinessName" class="form-control" placeholder="e.g. John's Plumbing Services" style="padding-left: 2.5rem;" />
                                    <i class="bi bi-building position-absolute" style="left: 1rem; top: 50%; transform: translateY(-50%); color: var(--text-muted);"></i>
                                </div>
                                <span asp-validation-for="BusinessName" class="text-danger small"></span>
                            </div>
                            
                            <div class="mb-4">
                                <label asp-for="Bio" class="form-label">About Your Business</label>
                                <textarea asp-for="Bio" class="form-control" rows="4" placeholder="Tell customers about your skills, experience, and what makes you stand out..."></textarea>
                                <span asp-validation-for="Bio" class="text-danger small"></span>
                                <div class="form-text">This will be displayed on your public profile.</div>
                            </div>
                            
                            <div class="mb-4">
                                <label asp-for="YearsOfExperience" class="form-label">Years of Experience</label>
                                <div class="position-relative">
                                    <input asp-for="YearsOfExperience" type="number" min="0" max="50" class="form-control" style="padding-left: 2.5rem;" />
                                    <i class="bi bi-award position-absolute" style="left: 1rem; top: 50%; transform: translateY(-50%); color: var(--text-muted);"></i>
                                </div>
                                <span asp-validation-for="YearsOfExperience" class="text-danger small"></span>
                            </div>
                            
                            <h5 class="mb-3 d-flex align-items-center">
                                <i class="bi bi-tags me-2 text-primary"></i> Additional Features
                            </h5>
                            <div class="row g-3 mb-4">
                                <div class="col-md-4">
                                    <div class="glass p-3 rounded-lg text-center h-100">
                                        <input asp-for="IsPetFriendly" class="form-check-input" style="width: 1.5rem; height: 1.5rem;" />
                                        <label asp-for="IsPetFriendly" class="d-block mt-2 small">
                                            <i class="bi bi-heart d-block fs-4 mb-1 text-primary"></i>
                                            Pet Friendly
                                        </label>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="glass p-3 rounded-lg text-center h-100">
                                        <input asp-for="IsNonSmoker" class="form-check-input" style="width: 1.5rem; height: 1.5rem;" />
                                        <label asp-for="IsNonSmoker" class="d-block mt-2 small">
                                            <i class="bi bi-slash-circle d-block fs-4 mb-1 text-primary"></i>
                                            Non-Smoker
                                        </label>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="glass p-3 rounded-lg text-center h-100">
                                        <input asp-for="HasOwnSupplies" class="form-check-input" style="width: 1.5rem; height: 1.5rem;" />
                                        <label asp-for="HasOwnSupplies" class="d-block mt-2 small">
                                            <i class="bi bi-box-seam d-block fs-4 mb-1 text-primary"></i>
                                            Own Supplies
                                        </label>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="d-grid">
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <i class="bi bi-arrow-right me-2"></i> Continue to Add Services
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
