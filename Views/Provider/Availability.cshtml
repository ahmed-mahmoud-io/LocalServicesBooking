@model LocalServicesBooking.Models.ViewModels.ManageAvailabilityViewModel

@{
    ViewData["Title"] = "Manage Availability";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow-sm">
                <div class="card-header bg-white border-bottom-0 pb-0">
                    <h3 class="fw-bold">Manage Availability</h3>
                    <p class="text-muted">Set your weekly working hours. Customers will only be able to book you during these times.</p>
                </div>
                <div class="card-body">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-action="Availability" method="post">
                        <div class="table-responsive">
                            <table class="table align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 150px;">Day</th>
                                        <th class="text-center" style="width: 100px;">Available</th>
                                        <th>Start Time</th>
                                        <th>End Time</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < Model.Availabilities.Count; i++)
                                    {
                                        <tr>
                                            <td>
                                                <input type="hidden" asp-for="Availabilities[i].DayOfWeek" />
                                                <span class="fw-medium">@Model.Availabilities[i].DayOfWeek</span>
                                            </td>
                                            <td class="text-center">
                                                <div class="form-check form-switch d-flex justify-content-center">
                                                    <input asp-for="Availabilities[i].IsAvailable" class="form-check-input" type="checkbox" role="switch">
                                                </div>
                                            </td>
                                            <td>
                                                <input asp-for="Availabilities[i].StartTime" type="time" class="form-control" />
                                            </td>
                                            <td>
                                                <input asp-for="Availabilities[i].EndTime" type="time" class="form-control" />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="d-flex justify-content-end mt-4">
                            <a asp-controller="Dashboard" asp-action="Provider" class="btn btn-outline-secondary me-2">Cancel</a>
                            <button type="submit" class="btn btn-primary px-4">Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
