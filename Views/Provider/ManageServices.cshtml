@model LocalServicesBooking.Models.ViewModels.ManageServicesViewModel

@{
    ViewData["Title"] = "Manage Services";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>My Services</h2>
        <a asp-action="AddService" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add New Service
        </a>
    </div>

    @if (!Model.Services.Any())
    {
        <div class="alert alert-info py-5 text-center">
            <h4 class="alert-heading">No Services Listed Yet</h4>
            <p>Start by adding your first service so customers can book you!</p>
            <a asp-action="AddService" class="btn btn-outline-primary mt-2">Add Service</a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var service in Model.Services)
            {
                <div class="col-md-6 mb-3">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">@service.ServiceName</h5>
                            <h6 class="card-subtitle mb-2 text-muted">@service.ServiceCategory?.CategoryName</h6>
                            <p class="card-text">@service.Description</p>
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <span class="badge bg-success fs-6">
                                    $@service.BasePrice / @service.PriceUnit
                                </span>
                                <small class="text-muted">
                                    <i class="bi bi-clock"></i> @service.DurationMinutes mins
                                </small>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
