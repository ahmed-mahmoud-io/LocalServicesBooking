@model LocalServicesBooking.Models.ViewModels.CustomerDashboardViewModel
@using Microsoft.AspNetCore.Identity
@using LocalServicesBooking.Models.Entities
@inject UserManager<User> UserManager

@{
    ViewData["Title"] = "My Dashboard";
    var user = await UserManager.GetUserAsync(User);
}

<!-- Dashboard Header -->
<section class="dashboard-header">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-8">
                <div class="d-flex align-items-center gap-4">
                    @{
                        var profileUrl = user?.ProfileImageUrl;
                        if (string.IsNullOrEmpty(profileUrl))
                        {
                            profileUrl = user?.Gender == "Male" ? "/images/defaults/default_male.png" :
                                         user?.Gender == "Female" ? "/images/defaults/default_female.png" :
                                         "/images/defaults/default_user.png";
                        }
                    }
                    <img src="@profileUrl" alt="Profile" class="rounded-circle" style="width: 80px; height: 80px; object-fit: cover; border: 3px solid var(--primary);">
                    <div>
                        <h2 class="mb-1" style="color: var(--text-primary);">Welcome back, @user?.FirstName!</h2>
                        <p class="mb-0" style="color: var(--text-secondary);">
                            <span class="badge badge-glass me-2"><i class="bi bi-person me-1"></i>Customer</span>
                            Member since @(user?.CreatedAt.ToString("MMMM yyyy") ?? "N/A")
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                <a asp-controller="Account" asp-action="Profile" class="btn btn-glass">
                    <i class="bi bi-gear me-2"></i>Edit Profile
                </a>
            </div>
        </div>
    </div>
</section>

<section class="py-4" style="background: var(--bg-primary);">
    <div class="container">
        <!-- Quick Stats -->
        <div class="dashboard-stats">
            <div class="stat-card" data-animate="fade-in-up">
                <div class="stat-card-icon">
                    <i class="bi bi-calendar-check"></i>
                </div>
                <div class="stat-card-value">@Model.UpcomingBookings.Count</div>
                <div class="stat-card-label">Upcoming Appointments</div>
            </div>
            <div class="stat-card" data-animate="fade-in-up">
                <div class="stat-card-icon" style="background: linear-gradient(135deg, #22c55e, #16a34a);">
                    <i class="bi bi-check-circle"></i>
                </div>
                <div class="stat-card-value">@Model.PastBookings.Count(b => b.Status == "Completed")</div>
                <div class="stat-card-label">Completed Services</div>
            </div>
            <div class="stat-card" data-animate="fade-in-up">
                <div class="stat-card-icon" style="background: linear-gradient(135deg, #f59e0b, #d97706);">
                    <i class="bi bi-heart"></i>
                </div>
                <div class="stat-card-value">0</div>
                <div class="stat-card-label">Favorite Providers</div>
            </div>
            <div class="stat-card" data-animate="fade-in-up">
                <div class="stat-card-icon" style="background: linear-gradient(135deg, #8b5cf6, #7c3aed);">
                    <i class="bi bi-chat-dots"></i>
                </div>
                <div class="stat-card-value">0</div>
                <div class="stat-card-label">Unread Messages</div>
            </div>
        </div>
        
        <div class="row g-4">
            <!-- Main Content -->
            <div class="col-lg-8">
                <!-- Customer Quick Actions -->
                <div class="card mb-4" data-animate="fade-in-up">
                    <div class="card-body">
                        <h5 class="mb-4" style="color: var(--text-primary);"><i class="bi bi-lightning me-2 text-primary"></i>Quick Actions</h5>
                        <div class="row g-3">
                            <div class="col-sm-6 col-md-4">
                                <a asp-controller="Search" asp-action="Index" class="btn btn-glass w-100 py-3">
                                    <i class="bi bi-search d-block fs-4 mb-2"></i>
                                    Find Services
                                </a>
                            </div>
                            <div class="col-sm-6 col-md-4">
                                <a asp-controller="Messaging" asp-action="Index" class="btn btn-glass w-100 py-3">
                                    <i class="bi bi-chat-dots d-block fs-4 mb-2"></i>
                                    Messages
                                </a>
                            </div>
                            <div class="col-sm-6 col-md-4">
                                <a asp-controller="Account" asp-action="Profile" class="btn btn-glass w-100 py-3">
                                    <i class="bi bi-person-gear d-block fs-4 mb-2"></i>
                                    Profile Settings
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Recent Bookings -->
                <div class="card" data-animate="fade-in-up">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h5 class="mb-0" style="color: var(--text-primary);"><i class="bi bi-clock-history me-2 text-primary"></i>My Bookings</h5>
                        </div>
                        
                        @if (Model.UpcomingBookings.Any())
                        {
                            <div class="list-group list-group-flush">
                                @foreach (var booking in Model.UpcomingBookings.Take(5))
                                {
                                    <div class="list-group-item" style="background: transparent; border-color: var(--border-color);">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <h6 class="mb-1" style="color: var(--text-primary);">@booking.Service?.ServiceName</h6>
                                                <p class="mb-0 small" style="color: var(--text-secondary);">
                                                    <i class="bi bi-calendar me-1"></i>@booking.BookingDate.ToString("MMM dd, yyyy")
                                                    <i class="bi bi-person ms-2 me-1"></i>@booking.Provider?.User?.FirstName @booking.Provider?.User?.LastName
                                                </p>
                                            </div>
                                            <span class="badge @(booking.Status == "Confirmed" ? "bg-success" : booking.Status == "Pending" ? "bg-warning" : "bg-secondary")">
                                                @booking.Status
                                            </span>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <!-- Empty State -->
                            <div class="empty-state py-4">
                                <div class="empty-state-icon" style="width: 60px; height: 60px; font-size: 1.5rem;">
                                    <i class="bi bi-calendar-x"></i>
                                </div>
                                <h6 class="empty-state-title" style="color: var(--text-primary);">No Bookings Yet</h6>
                                <p class="empty-state-text small" style="color: var(--text-secondary);">
                                    Start exploring services and book your first appointment!
                                </p>
                                <a asp-controller="Search" asp-action="Index" class="btn btn-primary btn-sm">
                                    <i class="bi bi-search me-2"></i>Find Services
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
            
            <!-- Sidebar -->
            <div class="col-lg-4">
                <!-- Messages Preview -->
                <div class="card mb-4" data-animate="fade-in-up">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h5 class="mb-0" style="color: var(--text-primary);"><i class="bi bi-chat-dots me-2 text-primary"></i>Messages</h5>
                            <a asp-controller="Messaging" asp-action="Index" class="text-primary text-decoration-none small">View All</a>
                        </div>
                        
                        <div class="text-center py-3">
                            <i class="bi bi-chat-square-text fs-1 mb-2 d-block" style="color: var(--text-muted);"></i>
                            <p class="small mb-0" style="color: var(--text-muted);">No new messages</p>
                        </div>
                    </div>
                </div>
                
                <!-- Customer Help -->
                <div class="card card-glass" data-animate="fade-in-up">
                    <div class="card-body">
                        <h5 class="mb-3" style="color: var(--text-primary);"><i class="bi bi-question-circle me-2 text-primary"></i>Need Help?</h5>
                        <p class="small mb-3" style="color: var(--text-secondary);">
                            Have questions about booking or using our platform?
                        </p>
                        <a href="#" class="btn btn-outline-primary btn-sm w-100">
                            <i class="bi bi-headset me-2"></i>Contact Support
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
