@model LocalServicesBooking.Models.ViewModels.ProviderDashboardViewModel
@using Microsoft.AspNetCore.Identity
@using LocalServicesBooking.Models.Entities
@inject UserManager<User> UserManager

@{
    ViewData["Title"] = "Provider Dashboard";
    var user = await UserManager.GetUserAsync(User);
}

<!-- Dashboard Header -->
<section class="dashboard-header">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-8">
                <div class="d-flex align-items-center gap-4">
                    @{
                        var profileUrl = user?.ProfileImageUrl;
                        if (string.IsNullOrEmpty(profileUrl))
                        {
                            profileUrl = user?.Gender == "Male" ? "/images/defaults/default_male.png" :
                                         user?.Gender == "Female" ? "/images/defaults/default_female.png" :
                                         "/images/defaults/default_user.png";
                        }
                    }
                    <img src="@profileUrl" alt="Profile" class="rounded-circle" style="width: 80px; height: 80px; object-fit: cover; border: 3px solid var(--primary);">
                    <div>
                        <h2 class="mb-1" style="color: var(--text-primary);">Welcome back, @user?.FirstName!</h2>
                        <p class="mb-0" style="color: var(--text-secondary);">
                            <span class="badge badge-primary me-2"><i class="bi bi-briefcase me-1"></i>Provider</span>
                            Member since @(user?.CreatedAt.ToString("MMMM yyyy") ?? "N/A")
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                <a asp-controller="Account" asp-action="Profile" class="btn btn-glass">
                    <i class="bi bi-gear me-2"></i>Edit Profile
                </a>
            </div>
        </div>
    </div>
</section>

<section class="py-4" style="background: var(--bg-primary);">
    <div class="container">
        <!-- Quick Stats -->
        <div class="dashboard-stats">
            <div class="stat-card" data-animate="fade-in-up">
                <div class="stat-card-icon">
                    <i class="bi bi-calendar-check"></i>
                </div>
                <div class="stat-card-value">@Model.UpcomingBookingsCount</div>
                <div class="stat-card-label">Upcoming Bookings</div>
            </div>
            <div class="stat-card" data-animate="fade-in-up">
                <div class="stat-card-icon" style="background: linear-gradient(135deg, #22c55e, #16a34a);">
                    <i class="bi bi-check-circle"></i>
                </div>
                <div class="stat-card-value">@Model.ActiveJobs.Count(j => j.Status == "Completed")</div>
                <div class="stat-card-label">Completed Jobs</div>
            </div>
            <div class="stat-card" data-animate="fade-in-up">
                <div class="stat-card-icon" style="background: linear-gradient(135deg, #f59e0b, #d97706);">
                    <i class="bi bi-star"></i>
                </div>
                <div class="stat-card-value">0.0</div>
                <div class="stat-card-label">Average Rating</div>
            </div>
            <div class="stat-card" data-animate="fade-in-up">
                <div class="stat-card-icon" style="background: linear-gradient(135deg, #8b5cf6, #7c3aed);">
                    <i class="bi bi-cash-stack"></i>
                </div>
                <div class="stat-card-value">$@Model.TotalEarnings.ToString("N0")</div>
                <div class="stat-card-label">Total Earnings</div>
            </div>
        </div>
        
        <div class="row g-4">
            <!-- Main Content -->
            <div class="col-lg-8">
                <!-- Provider Quick Actions -->
                <div class="card mb-4" data-animate="fade-in-up">
                    <div class="card-body">
                        <h5 class="mb-4" style="color: var(--text-primary);"><i class="bi bi-lightning me-2 text-primary"></i>Quick Actions</h5>
                        <div class="row g-3">
                            <div class="col-sm-6 col-md-4">
                                <a asp-controller="Provider" asp-action="ManageServices" class="btn btn-glass w-100 py-3">
                                    <i class="bi bi-box-seam d-block fs-4 mb-2"></i>
                                    Manage Services
                                </a>
                            </div>
                            <div class="col-sm-6 col-md-4">
                                <a asp-controller="Provider" asp-action="Availability" class="btn btn-glass w-100 py-3">
                                    <i class="bi bi-calendar3 d-block fs-4 mb-2"></i>
                                    Set Availability
                                </a>
                            </div>
                            <div class="col-sm-6 col-md-4">
                                <a asp-controller="Messaging" asp-action="Index" class="btn btn-glass w-100 py-3">
                                    <i class="bi bi-chat-dots d-block fs-4 mb-2"></i>
                                    Messages
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Active Jobs -->
                <div class="card" data-animate="fade-in-up">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h5 class="mb-0" style="color: var(--text-primary);"><i class="bi bi-briefcase me-2 text-primary"></i>Active Jobs</h5>
                        </div>
                        
                        @if (Model.ActiveJobs.Any())
                        {
                            <div class="list-group list-group-flush">
                                @foreach (var job in Model.ActiveJobs.Take(5))
                                {
                                    <div class="list-group-item" style="background: transparent; border-color: var(--border-color);">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <h6 class="mb-1" style="color: var(--text-primary);">@job.Service?.ServiceName</h6>
                                                <p class="mb-0 small" style="color: var(--text-secondary);">
                                                    <i class="bi bi-calendar me-1"></i>@job.BookingDate.ToString("MMM dd, yyyy")
                                                    <i class="bi bi-person ms-2 me-1"></i>@job.Customer?.FirstName @job.Customer?.LastName
                                                </p>
                                            </div>
                                            <span class="badge @(job.Status == "Confirmed" ? "bg-success" : job.Status == "Pending" ? "bg-warning" : "bg-info")">
                                                @job.Status
                                            </span>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <!-- Empty State -->
                            <div class="empty-state py-4">
                                <div class="empty-state-icon" style="width: 60px; height: 60px; font-size: 1.5rem;">
                                    <i class="bi bi-calendar-x"></i>
                                </div>
                                <h6 class="empty-state-title" style="color: var(--text-primary);">No Active Jobs</h6>
                                <p class="empty-state-text small" style="color: var(--text-secondary);">
                                    When customers book your services, they'll appear here.
                                </p>
                            </div>
                        }
                    </div>
                </div>
            </div>
            
            <!-- Sidebar -->
            <div class="col-lg-4">
                <!-- New Requests -->
                <div class="card mb-4" data-animate="fade-in-up">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h5 class="mb-0" style="color: var(--text-primary);"><i class="bi bi-bell me-2 text-primary"></i>New Requests</h5>
                            <span class="badge bg-primary">@Model.NewRequestsCount</span>
                        </div>
                        
                        @if (Model.NewRequestsCount > 0)
                        {
                            <p class="small" style="color: var(--text-secondary);">You have @Model.NewRequestsCount pending request(s) waiting for your response.</p>
                        }
                        else
                        {
                            <div class="text-center py-3">
                                <i class="bi bi-inbox fs-1 mb-2 d-block" style="color: var(--text-muted);"></i>
                                <p class="small mb-0" style="color: var(--text-muted);">No pending requests</p>
                            </div>
                        }
                    </div>
                </div>
                
                <!-- Provider Tips -->
                <div class="card card-glass" data-animate="fade-in-up">
                    <div class="card-body">
                        <h5 class="mb-3" style="color: var(--text-primary);"><i class="bi bi-lightbulb me-2 text-warning"></i>Pro Tips</h5>
                        <ul class="list-unstyled mb-0">
                            <li class="mb-2 d-flex align-items-start">
                                <i class="bi bi-check-circle-fill text-success me-2 mt-1"></i>
                                <span class="small" style="color: var(--text-secondary);">Complete your profile to attract more customers</span>
                            </li>
                            <li class="mb-2 d-flex align-items-start">
                                <i class="bi bi-check-circle-fill text-success me-2 mt-1"></i>
                                <span class="small" style="color: var(--text-secondary);">Respond to inquiries quickly for better ratings</span>
                            </li>
                            <li class="d-flex align-items-start">
                                <i class="bi bi-check-circle-fill text-success me-2 mt-1"></i>
                                <span class="small" style="color: var(--text-secondary);">Keep your availability calendar updated</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
