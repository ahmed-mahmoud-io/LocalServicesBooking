@{
    ViewData["Title"] = "Design System Showcase";
}

<div class="container py-5">
    @* Header *@
    <div class="text-center mb-5">
        <h1 class="mb-3">Design System Showcase</h1>
        <p class="lead text-muted">Modern booking platform components with dark/light theme support</p>
        <div class="d-flex justify-content-center gap-3 mt-4">
            <button id="theme-toggle-demo" class="btn btn-outline-primary">
                <i class="bi bi-moon-fill me-2"></i>Toggle Theme
            </button>
        </div>
    </div>

    @* Color Palette Showcase *@
    <section class="mb-5">
        <h2 class="mb-4">Color Palette</h2>
        <div class="row g-3">
            <div class="col-md-3">
                <div class="p-4 rounded-3 text-center" style="background: var(--primary); color: white;">
                    <h5>Primary</h5>
                    <small>Trust & Professional</small>
                </div>
            </div>
            <div class="col-md-3">
                <div class="p-4 rounded-3 text-center" style="background: var(--accent); color: white;">
                    <h5>Accent</h5>
                    <small>Conversion Focus</small>
                </div>
            </div>
            <div class="col-md-3">
                <div class="p-4 rounded-3 text-center" style="background: var(--success); color: white;">
                    <h5>Success</h5>
                    <small>Confirmed</small>
                </div>
            </div>
            <div class="col-md-3">
                <div class="p-4 rounded-3 text-center" style="background: var(--price-highlight); color: white;">
                    <h5>Price</h5>
                    <small>Highlight</small>
                </div>
            </div>
        </div>
    </section>

    @* Buttons Showcase *@
    <section class="mb-5">
        <h2 class="mb-4">Booking Buttons</h2>
        <div class="d-flex flex-wrap gap-3">
            <button class="btn btn-booking-primary">
                <i class="bi bi-calendar-check me-2"></i>Book Now
            </button>
            <button class="btn btn-booking-secondary">View Details</button>
            <button class="btn-icon-only">
                <i class="bi bi-heart"></i>
            </button>
            <button class="btn-icon-only active">
                <i class="bi bi-heart-fill"></i>
            </button>
        </div>
    </section>

    @* Booking Status Badges *@
    <section class="mb-5">
        <h2 class="mb-4">Booking Status</h2>
        <div class="d-flex flex-wrap gap-3">
            <span class="booking-status booking-status-confirmed">
                <i class="bi bi-check-circle-fill"></i>Confirmed
            </span>
            <span class="booking-status booking-status-pending">
                <i class="bi bi-clock-fill"></i>Pending
            </span>
            <span class="booking-status booking-status-cancelled">
                <i class="bi bi-x-circle-fill"></i>Cancelled
            </span>
        </div>
    </section>

    @* Service Cards Grid *@
    <section class="mb-5">
        <h2 class="mb-4">Service Cards</h2>
        <div class="services-grid">
            @* Example Service Card 1 *@
            <div class="service-card">
                <div class="service-card-image">
                    <img src="https://images.unsplash.com/photo-1521737711867-e3b97375f902?w=800&h=450&fit=crop" alt="Professional Cleaning">
                    <div class="service-card-badge badge-popular">Popular</div>
                </div>
                <div class="service-card-body">
                    <h3 class="service-card-title">Professional Home Cleaning</h3>
                    <div class="service-card-provider">
                        <img src="https://i.pravatar.cc/48?img=1" alt="Provider">
                        <span>Sarah Johnson</span>
                    </div>
                    <div class="service-card-rating">
                        <i class="bi bi-star-fill"></i>
                        <span class="service-card-rating-value">4.9</span>
                        <span class="service-card-rating-count">(127 reviews)</span>
                    </div>
                    <p class="service-card-description">
                        Deep cleaning service for your home with eco-friendly products. 
                        Professional, reliable, and thorough.
                    </p>
                    <div class="service-card-meta">
                        <div class="service-card-meta-item">
                            <i class="bi bi-clock"></i>
                            <span>2-3 hours</span>
                        </div>
                        <div class="service-card-meta-item">
                            <i class="bi bi-geo-alt"></i>
                            <span>Downtown</span>
                        </div>
                    </div>
                </div>
                <div class="service-card-footer">
                    <div class="service-card-price">
                        <span class="service-card-price-label">From</span>
                        <span class="service-card-price-value">$89</span>
                        <span class="service-card-price-period">/ session</span>
                    </div>
                    <div class="service-card-actions">
                        <button class="btn btn-booking-primary">
                            <i class="bi bi-calendar-check me-2"></i>Book Now
                        </button>
                        <button class="btn btn-booking-secondary">Details</button>
                    </div>
                </div>
            </div>

            @* Example Service Card 2 *@
            <div class="service-card">
                <div class="service-card-image">
                    <img src="https://images.unsplash.com/photo-1560518883-ce09059eeffa?w=800&h=450&fit=crop" alt="Plumbing Service">
                    <div class="service-card-badge badge-featured">Featured</div>
                </div>
                <div class="service-card-body">
                    <h3 class="service-card-title">Emergency Plumbing Repair</h3>
                    <div class="service-card-provider">
                        <img src="https://i.pravatar.cc/48?img=12" alt="Provider">
                        <span>Mike Thompson</span>
                    </div>
                    <div class="service-card-rating">
                        <i class="bi bi-star-fill"></i>
                        <span class="service-card-rating-value">4.8</span>
                        <span class="service-card-rating-count">(89 reviews)</span>
                    </div>
                    <p class="service-card-description">
                        24/7 emergency plumbing services. Licensed and insured professional 
                        with 10+ years experience.
                    </p>
                    <div class="service-card-meta">
                        <div class="service-card-meta-item">
                            <i class="bi bi-clock"></i>
                            <span>1-2 hours</span>
                        </div>
                        <div class="service-card-meta-item">
                            <i class="bi bi-geo-alt"></i>
                            <span>Citywide</span>
                        </div>
                    </div>
                </div>
                <div class="service-card-footer">
                    <div class="service-card-price">
                        <span class="service-card-price-label">From</span>
                        <span class="service-card-price-value">$125</span>
                        <span class="service-card-price-period">/ hour</span>
                    </div>
                    <div class="service-card-actions">
                        <button class="btn btn-booking-primary">
                            <i class="bi bi-calendar-check me-2"></i>Book Now
                        </button>
                        <button class="btn btn-booking-secondary">Details</button>
                    </div>
                </div>
            </div>

            @* Example Service Card 3 *@
            <div class="service-card">
                <div class="service-card-image">
                    <img src="https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=800&h=450&fit=crop" alt="Electrical Services">
                    <div class="service-card-badge badge-new">New</div>
                </div>
                <div class="service-card-body">
                    <h3 class="service-card-title">Certified Electrical Installation</h3>
                    <div class="service-card-provider">
                        <img src="https://i.pravatar.cc/48?img=33" alt="Provider">
                        <span>David Lee</span>
                    </div>
                    <div class="service-card-rating">
                        <i class="bi bi-star-fill"></i>
                        <span class="service-card-rating-value">5.0</span>
                        <span class="service-card-rating-count">(45 reviews)</span>
                    </div>
                    <p class="service-card-description">
                        Complete electrical installation and repair services. 
                        Safety certified with warranty included.
                    </p>
                    <div class="service-card-meta">
                        <div class="service-card-meta-item">
                            <i class="bi bi-clock"></i>
                            <span>2-4 hours</span>
                        </div>
                        <div class="service-card-meta-item">
                            <i class="bi bi-geo-alt"></i>
                            <span>Metro Area</span>
                        </div>
                    </div>
                </div>
                <div class="service-card-footer">
                    <div class="service-card-price">
                        <span class="service-card-price-label">From</span>
                        <span class="service-card-price-value">$99</span>
                        <span class="service-card-price-period">/ job</span>
                    </div>
                    <div class="service-card-actions">
                        <button class="btn btn-booking-primary">
                            <i class="bi bi-calendar-check me-2"></i>Book Now
                        </button>
                        <button class="btn btn-booking-secondary">Details</button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* Calendar Picker *@
    <section class="mb-5">
        <h2 class="mb-4">Calendar & Time Slot Picker</h2>
        <div class="row">
            <div class="col-lg-8 mx-auto">
                <partial name="_CalendarPicker" />
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script>
        // Demo theme toggle
        document.getElementById('theme-toggle-demo')?.addEventListener('click', () => {
            ThemeManager.toggle();
        });
    </script>
}
