@{
    ViewData["Title"] = "Community Chat";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0"><i class="bi bi-chat-dots me-2"></i>Community Chat</h4>
                    <span id="connection-status" class="badge bg-warning text-dark">Connecting...</span>
                </div>
                <div class="card-body p-0">
                    <div id="chat-messages" class="p-3" style="height: 500px; overflow-y: auto; background-color: #f8f9fa;">
                        <!-- Messages will appear here -->
                        <div class="text-center text-muted mt-5">Loading messages...</div>
                    </div>
                </div>
                <div class="card-footer">
                    <form id="chat-form" class="d-flex gap-2">
                        <input type="text" id="message-input" class="form-control" placeholder="Type your message..." required disabled>
                        <button type="submit" id="send-btn" class="btn btn-primary" disabled>
                            <i class="bi bi-send"></i>
                        </button>
                    </form>
                    <div id="auth-warning" class="text-danger small mt-2" style="display: none;">
                        You must be logged in to post messages.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .message-bubble {
        max-width: 80%;
        margin-bottom: 1rem;
        padding: 0.75rem 1rem;
        border-radius: 1rem;
        position: relative;
    }
    .message-mine {
        background-color: var(--bs-primary);
        color: white;
        margin-left: auto;
        border-bottom-right-radius: 0.25rem;
    }
    .message-others {
        background-color: white;
        border: 1px solid #dee2e6;
        margin-right: auto;
        border-bottom-left-radius: 0.25rem;
    }
    .message-meta {
        font-size: 0.75rem;
        margin-bottom: 0.25rem;
        opacity: 0.8;
    }
    .message-time {
        font-size: 0.7rem;
        opacity: 0.7;
        text-align: right;
        display: block;
        margin-top: 0.25rem;
    }
</style>

@section Scripts {
    <script type="module">
        import { db, auth } from '/js/firebase-config.js';
        import { collection, addDoc, query, orderBy, limit, onSnapshot, serverTimestamp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js";
        import { onAuthStateChanged } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-auth.js";

        const messagesContainer = document.getElementById('chat-messages');
        const chatForm = document.getElementById('chat-form');
        const messageInput = document.getElementById('message-input');
        const sendBtn = document.getElementById('send-btn');
        const connectionStatus = document.getElementById('connection-status');
        const authWarning = document.getElementById('auth-warning');

        let currentUser = null;

        // Monitor Auth State
        onAuthStateChanged(auth, (user) => {
            currentUser = user;
            if (user) {
                messageInput.disabled = false;
                sendBtn.disabled = false;
                authWarning.style.display = 'none';
                messageInput.placeholder = `Message as ${user.displayName || user.email}...`;
            } else {
                messageInput.disabled = true;
                sendBtn.disabled = true;
                authWarning.style.display = 'block';
                messageInput.placeholder = "Please login to chat";
            }
        });

        // Listen for Messages
        const q = query(collection(db, "community_messages"), orderBy("createdAt", "asc"), limit(50));
        
        onSnapshot(q, (snapshot) => {
            connectionStatus.textContent = "Connected";
            connectionStatus.className = "badge bg-success";
            
            messagesContainer.innerHTML = '';
            
            if (snapshot.empty) {
                messagesContainer.innerHTML = '<div class="text-center text-muted mt-5">No messages yet. Be the first!</div>';
                return;
            }

            snapshot.forEach((doc) => {
                const msg = doc.data();
                const isMine = currentUser && msg.uid === currentUser.uid;
                
                const div = document.createElement('div');
                div.className = `message-bubble ${isMine ? 'message-mine' : 'message-others'}`;
                
                const time = msg.createdAt ? new Date(msg.createdAt.seconds * 1000).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) : 'Sending...';
                
                div.innerHTML = `
                    <div class="message-meta">${isMine ? 'You' : (msg.displayName || 'Anonymous')}</div>
                    <div class="message-text">${escapeHtml(msg.text)}</div>
                    <span class="message-time">${time}</span>
                `;
                
                messagesContainer.appendChild(div);
            });
            
            // Auto scroll to bottom
            messagesContainer.scrollTop = messagesContainer.scrollHeight;
        });

        // Send Message
        chatForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const text = messageInput.value.trim();
            if (!text || !currentUser) return;

            try {
                await addDoc(collection(db, "community_messages"), {
                    text: text,
                    uid: currentUser.uid,
                    displayName: currentUser.displayName || currentUser.email,
                    photoURL: currentUser.photoURL,
                    createdAt: serverTimestamp()
                });
                messageInput.value = '';
            } catch (error) {
                console.error("Error sending message:", error);
                alert("Failed to send message: " + error.message);
            }
        });

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }
    </script>
}
