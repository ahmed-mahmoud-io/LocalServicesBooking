@using Microsoft.AspNetCore.Identity
@inject SignInManager<LocalServicesBooking.Models.Entities.User> SignInManager
@inject UserManager<LocalServicesBooking.Models.Entities.User> UserManager

@{
    ViewData["Title"] = "Community Chat";
    var isLoggedIn = SignInManager.IsSignedIn(User);
    var currentUser = isLoggedIn ? await UserManager.GetUserAsync(User) : null;
    var displayName = currentUser != null ? $"{currentUser.FirstName} {currentUser.LastName}" : "Guest";
    var userId = currentUser?.Id.ToString() ?? "";
    var avatarUrl = currentUser?.ProfileImageUrl;
    if (string.IsNullOrEmpty(avatarUrl))
    {
        avatarUrl = currentUser?.Gender == "Male" ? "/images/defaults/default_male.png" :
                   currentUser?.Gender == "Female" ? "/images/defaults/default_female.png" :
                   "/images/defaults/default_user.png";
    }
}

<div class="container py-4" style="max-width: 1200px;">
    <div class="row">
        <div class="col-12">
            <!-- Chat Card -->
            <div class="card shadow-sm">
                <!-- Header -->
                <div class="card-header p-3" style="background: var(--gradient-primary); border: none;">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center gap-3">
                            <div class="d-flex align-items-center justify-content-center rounded-circle" 
                                 style="width: 45px; height: 45px; background: rgba(255,255,255,0.2);">
                                <i class="bi bi-chat-heart-fill fs-5 text-white"></i>
                            </div>
                            <div>
                                <h5 class="mb-0 text-white fw-bold">Community Chat</h5>
                                <small class="text-white-50">Real-time conversation</small>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <span id="online-count" class="badge" style="background: rgba(255,255,255,0.2); color: white;">
                                <i class="bi bi-people-fill me-1"></i><span id="count-value">0</span> online
                            </span>
                            <span id="connection-status" class="badge bg-warning text-dark">
                                <i class="bi bi-wifi me-1"></i>Connecting...
                            </span>
                        </div>
                    </div>
                </div>
                
                <!-- Messages Area -->
                <div class="card-body p-0">
                    <div id="chat-messages" class="chat-messages p-3">
                        <div class="text-center py-5">
                            <div class="spinner-border text-primary mb-3" role="status"></div>
                            <p style="color: var(--text-muted);">Loading messages...</p>
                        </div>
                    </div>
                </div>
                
                <!-- Input Area -->
                <div class="card-footer p-3" style="background: var(--bg-secondary); border-top: 1px solid var(--border-color);">
                    @if (isLoggedIn)
                    {
                        <!-- Image Preview -->
                        <div id="image-preview-container" class="mb-2" style="display: none;">
                            <div class="position-relative d-inline-block">
                                <img id="image-preview" src="" alt="Preview" style="max-height: 120px; border-radius: var(--radius-md); border: 2px solid var(--border-color);">
                                <button type="button" id="remove-image" class="btn btn-danger btn-sm position-absolute" 
                                        style="top: -8px; right: -8px; padding: 4px 8px; border-radius: 50%;">
                                    <i class="bi bi-x"></i>
                                </button>
                            </div>
                        </div>
                        
                        <form id="chat-form" class="d-flex gap-2 align-items-end">
                            <!-- Image Upload -->
                            <input type="file" id="image-input" accept="image/*" style="display: none;">
                            <button type="button" id="image-btn" class="btn btn-outline-secondary" title="Upload image" style="flex-shrink: 0;">
                                <i class="bi bi-image"></i>
                            </button>
                            
                            <!-- Message Input -->
                            <div class="flex-grow-1 position-relative">
                                <textarea id="message-input" 
                                       class="form-control" 
                                       placeholder="Type your message..."
                                       rows="1"
                                       style="resize: none; padding-right: 45px; min-height: 42px;"></textarea>
                                <button type="button" id="emoji-btn" class="btn btn-link position-absolute" 
                                        style="right: 5px; top: 50%; transform: translateY(-50%); color: var(--text-muted); padding: 0.25rem 0.5rem;"
                                        title="Emoji">
                                    <i class="bi bi-emoji-smile fs-5"></i>
                                </button>
                            </div>
                            
                            <!-- Send Button -->
                            <button type="submit" id="send-btn" class="btn btn-primary px-3" style="flex-shrink: 0;">
                                <i class="bi bi-send-fill"></i>
                            </button>
                        </form>
                        
                        <!-- Emoji Picker -->
                        <div id="emoji-picker" class="emoji-picker" style="display: none;">
                            <div class="emoji-grid">
                                <span class="emoji" data-emoji="😀">😀</span>
                                <span class="emoji" data-emoji="😂">😂</span>
                                <span class="emoji" data-emoji="😍">😍</span>
                                <span class="emoji" data-emoji="🥰">🥰</span>
                                <span class="emoji" data-emoji="😎">😎</span>
                                <span class="emoji" data-emoji="🤔">🤔</span>
                                <span class="emoji" data-emoji="👍">👍</span>
                                <span class="emoji" data-emoji="👏">👏</span>
                                <span class="emoji" data-emoji="🙏">🙏</span>
                                <span class="emoji" data-emoji="❤️">❤️</span>
                                <span class="emoji" data-emoji="🔥">🔥</span>
                                <span class="emoji" data-emoji="✨">✨</span>
                                <span class="emoji" data-emoji="🎉">🎉</span>
                                <span class="emoji" data-emoji="💯">💯</span>
                                <span class="emoji" data-emoji="👀">👀</span>
                                <span class="emoji" data-emoji="😢">😢</span>
                                <span class="emoji" data-emoji="😮">😮</span>
                                <span class="emoji" data-emoji="🤣">🤣</span>
                                <span class="emoji" data-emoji="😊">😊</span>
                                <span class="emoji" data-emoji="🙂">🙂</span>
                                <span class="emoji" data-emoji="😘">😘</span>
                                <span class="emoji" data-emoji="😉">😉</span>
                                <span class="emoji" data-emoji="🤗">🤗</span>
                                <span class="emoji" data-emoji="😭">😭</span>
                                <span class="emoji" data-emoji="😱">😱</span>
                                <span class="emoji" data-emoji="👋">👋</span>
                                <span class="emoji" data-emoji="💪">💪</span>
                                <span class="emoji" data-emoji="🤝">🤝</span>
                                <span class="emoji" data-emoji="💖">💖</span>
                                <span class="emoji" data-emoji="⭐">⭐</span>
                            </div>
                        </div>
                        
                        <div class="mt-2 d-flex align-items-center gap-2">
                            <img src="@avatarUrl" alt="You" class="rounded-circle" style="width: 24px; height: 24px; object-fit: cover;">
                            <small style="color: var(--text-muted);">Chatting as <strong style="color: var(--text-primary);">@displayName</strong></small>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-3">
                            <i class="bi bi-lock-fill fs-4 mb-2 d-block" style="color: var(--text-muted);"></i>
                            <p class="mb-3" style="color: var(--text-secondary);">Login to join the conversation</p>
                            <a asp-controller="Account" asp-action="Login" class="btn btn-primary">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Login to Chat
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .chat-messages {
        height: 500px;
        overflow-y: auto;
        background: var(--bg-primary);
        scroll-behavior: smooth;
    }
    
    .chat-messages::-webkit-scrollbar {
        width: 6px;
    }
    
    .chat-messages::-webkit-scrollbar-track {
        background: transparent;
    }
    
    .chat-messages::-webkit-scrollbar-thumb {
        background: var(--border-color);
        border-radius: 3px;
    }
    
    .message-bubble {
        max-width: 75%;
        margin-bottom: 1rem;
        animation: slideIn 0.3s ease;
    }
    
    @keyframes slideIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    
    .message-mine {
        margin-left: auto;
        text-align: right;
    }
    
    .message-mine .message-content {
        background: var(--gradient-primary);
        color: white;
        border-radius: 18px 18px 4px 18px;
        padding: 0.75rem 1rem;
        display: inline-block;
        text-align: left;
        word-wrap: break-word;
    }
    
    .message-others {
        margin-right: auto;
    }
    
    .message-others .message-content {
        background: var(--bg-secondary);
        border: 1px solid var(--border-color);
        color: var(--text-primary);
        border-radius: 18px 18px 18px 4px;
        padding: 0.75rem 1rem;
        display: inline-block;
        word-wrap: break-word;
    }
    
    .message-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.5rem;
    }
    
    .message-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        object-fit: cover;
        flex-shrink: 0;
    }
    
    .message-sender {
        font-weight: 600;
        font-size: 0.875rem;
        color: var(--text-primary);
    }
    
    .message-time {
        font-size: 0.7rem;
        color: var(--text-muted);
        margin-top: 0.25rem;
    }
    
    .message-mine .message-time {
        color: rgba(255,255,255,0.7);
    }
    
    .message-image {
        max-width: 100%;
        max-height: 300px;
        border-radius: 12px;
        margin-top: 0.5rem;
        cursor: pointer;
        display: block;
    }
    
    .mention {
        background: rgba(138, 43, 226, 0.2);
        color: var(--primary);
        padding: 0 4px;
        border-radius: 4px;
        font-weight: 500;
    }
    
    .emoji-picker {
        position: absolute;
        bottom: 100%;
        right: 0;
        background: var(--bg-primary);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-lg);
        padding: 0.75rem;
        box-shadow: 0 10px 40px rgba(0,0,0,0.2);
        z-index: 1000;
        margin-bottom: 10px;
        max-width: 280px;
    }
    
    .emoji-grid {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: 4px;
    }
    
    .emoji {
        font-size: 1.5rem;
        padding: 0.25rem;
        cursor: pointer;
        border-radius: 6px;
        text-align: center;
        transition: background 0.2s;
        user-select: none;
    }
    
    .emoji:hover {
        background: var(--bg-secondary);
    }
    
    .empty-state {
        text-align: center;
        padding: 3rem 1rem;
    }
    
    .empty-state i {
        font-size: 4rem;
        color: var(--text-muted);
        margin-bottom: 1rem;
    }
    
    /* Light Mode Enhancements */
    [data-theme="light"] .message-others .message-content {
        background: #f0f2f5;
        border-color: #e0e0e0;
    }
    
    [data-theme="light"] .chat-messages {
        background: #fafafa;
    }
    
    #message-input {
        max-height: 120px;
        overflow-y: auto;
    }
</style>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        const isLoggedIn = @(isLoggedIn ? "true" : "false");
        const currentUserId = "@userId";
        const currentDisplayName = "@Html.Raw(displayName.Replace("\"", "\\\""))";
        const currentAvatarUrl = "@Html.Raw(avatarUrl?.Replace("\"", "\\\"") ?? "")";
        
        if (isLoggedIn) {
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/chatHub")
                .withAutomaticReconnect()
                .build();
            
            const messagesContainer = document.getElementById('chat-messages');
            const chatForm = document.getElementById('chat-form');
            const messageInput = document.getElementById('message-input');
            const connectionStatus = document.getElementById('connection-status');
            const sendBtn = document.getElementById('send-btn');
            const emojiBtn = document.getElementById('emoji-btn');
            const emojiPicker = document.getElementById('emoji-picker');
            const imageBtn = document.getElementById('image-btn');
            const imageInput = document.getElementById('image-input');
            const imagePreviewContainer = document.getElementById('image-preview-container');
            const imagePreview = document.getElementById('image-preview');
            const removeImageBtn = document.getElementById('remove-image');
            const countValue = document.getElementById('count-value');
            
            let uploadedImageUrl = null;
            
            // Auto-resize textarea
            messageInput.addEventListener('input', function() {
                this.style.height = 'auto';
                this.style.height = Math.min(this.scrollHeight, 120) + 'px';
            });
            
            // Emoji Picker
            emojiBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                emojiPicker.style.display = emojiPicker.style.display === 'none' ? 'block' : 'none';
            });
            
            document.querySelectorAll('.emoji').forEach(emoji => {
                emoji.addEventListener('click', () => {
                    messageInput.value += emoji.dataset.emoji;
                    messageInput.focus();
                    emojiPicker.style.display = 'none';
                });
            });
            
            document.addEventListener('click', (e) => {
                if (!emojiPicker.contains(e.target) && e.target !== emojiBtn && !e.target.closest('#emoji-btn')) {
                    emojiPicker.style.display = 'none';
                }
            });
            
            // Image Upload
            imageBtn.addEventListener('click', () => imageInput.click());
            
            imageInput.addEventListener('change', async (e) => {
                const file = e.target.files[0];
                if (!file) return;
                
                // Show preview
                const reader = new FileReader();
                reader.onload = (e) => {
                    imagePreview.src = e.target.result;
                    imagePreviewContainer.style.display = 'block';
                };
                reader.readAsDataURL(file);
                
                // Upload to server
                const formData = new FormData();
                formData.append('image', file);
                
                try {
                    imageBtn.disabled = true;
                    imageBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
                    
                    const response = await fetch('/Chat/UploadImage', {
                        method: 'POST',
                        body: formData
                    });
                    
                    if (!response.ok) {
                        const error = await response.json();
                        throw new Error(error.error || 'Upload failed');
                    }
                    
                    const data = await response.json();
                    uploadedImageUrl = data.url;
                } catch (err) {
                    console.error('Upload error:', err);
                    alert('Failed to upload image: ' + err.message);
                    removeImageBtn.click();
                } finally {
                    imageBtn.disabled = false;
                    imageBtn.innerHTML = '<i class="bi bi-image"></i>';
                }
            });
            
            removeImageBtn.addEventListener('click', () => {
                uploadedImageUrl = null;
                imageInput.value = '';
                imagePreviewContainer.style.display = 'none';
            });
            
            // Connection status
            connection.onreconnecting(() => {
                connectionStatus.innerHTML = '<i class="bi bi-wifi me-1"></i>Reconnecting...';
                connectionStatus.className = 'badge bg-warning text-dark';
            });
            
            connection.onreconnected(() => {
                connectionStatus.innerHTML = '<i class="bi bi-wifi me-1"></i>Connected';
                connectionStatus.className = 'badge bg-success';
            });
            
            connection.onclose(() => {
                connectionStatus.innerHTML = '<i class="bi bi-wifi-off me-1"></i>Disconnected';
                connectionStatus.className = 'badge bg-danger';
            });
            
            // Receive messages
            connection.on("ReceiveCommunityMessage", (msgId, usrId, dispName, message, imgUrl, avatarUrl, time) => {
                addMessage(msgId, usrId, dispName, message, imgUrl, avatarUrl, time);
            });
            
            // Update online count
            connection.on("UpdateOnlineCount", (count) => {
                countValue.textContent = count;
            });
            
            function addMessage(msgId, usrId, dispName, message, imgUrl, avatarUrl, time) {
                const isMine = usrId === currentUserId;
                
                // Remove loading/empty state
                const loading = messagesContainer.querySelector('.spinner-border');
                if (loading) loading.closest('.text-center').remove();
                
                const emptyState = messagesContainer.querySelector('.empty-state');
                if (emptyState) emptyState.remove();
                
                const div = document.createElement('div');
                div.className = `message-bubble ${isMine ? 'message-mine' : 'message-others'}`;
                div.dataset.messageId = msgId;
                
                // Process mentions
                const processedMessage = escapeHtml(message).replace(/@@(\w+)/g, '<span class="mention">@@$1</span>');
                
                let imageHtml = '';
                if (imgUrl) {
                    imageHtml = `<img src="${imgUrl}" class="message-image" onclick="window.open('${imgUrl}', '_blank')" alt="Shared image">`;
                }
                
                if (!isMine) {
                    div.innerHTML = `
                        <div class="message-header">
                            <img src="${avatarUrl || '/images/defaults/default_user.png'}" class="message-avatar" alt="${escapeHtml(dispName)}">
                            <span class="message-sender">${escapeHtml(dispName)}</span>
                        </div>
                        <div class="message-content">${processedMessage}${imageHtml}</div>
                        <div class="message-time">${time}</div>
                    `;
                } else {
                    div.innerHTML = `
                        <div class="message-content">${processedMessage}${imageHtml}</div>
                        <div class="message-time">${time}</div>
                    `;
                }
                
                messagesContainer.appendChild(div);
                scrollToBottom();
            }
            
            function scrollToBottom() {
                messagesContainer.scrollTop = messagesContainer.scrollHeight;
            }
            
            function escapeHtml(text) {
                const div = document.createElement('div');
                div.textContent = text;
                return div.innerHTML;
            }
            
            function showEmptyState() {
                messagesContainer.innerHTML = `
                    <div class="empty-state">
                        <i class="bi bi-chat-square-heart"></i>
                        <h5 style="color: var(--text-primary);">No messages yet</h5>
                        <p style="color: var(--text-muted);">Be the first to start the conversation!</p>
                    </div>
                `;
            }
            
            async function loadMessages() {
                try {
                    const messages = await connection.invoke("GetRecentMessages", 50);
                    messagesContainer.innerHTML = '';
                    
                    if (messages.length === 0) {
                        showEmptyState();
                    } else {
                        messages.forEach(msg => {
                            addMessage(msg.messageId, msg.userId, msg.displayName, msg.text, msg.imageUrl, msg.avatarUrl, msg.time);
                        });
                    }
                } catch (err) {
                    console.error('Failed to load messages:', err);
                    showEmptyState();
                }
            }
            
            // Start connection
            connection.start()
                .then(async () => {
                    connectionStatus.innerHTML = '<i class="bi bi-wifi me-1"></i>Connected';
                    connectionStatus.className = 'badge bg-success';
                    
                    await connection.invoke("JoinCommunityChat");
                    await loadMessages();
                    messageInput.focus();
                })
                .catch(err => {
                    console.error('Connection error:', err);
                    connectionStatus.innerHTML = '<i class="bi bi-wifi-off me-1"></i>Failed';
                    connectionStatus.className = 'badge bg-danger';
                    messagesContainer.innerHTML = `
                        <div class="text-center py-5">
                            <i class="bi bi-exclamation-triangle fs-1 text-warning mb-3 d-block"></i>
                            <p style="color: var(--text-secondary);">Failed to connect to chat server</p>
                            <button class="btn btn-outline-primary btn-sm" onclick="location.reload()">
                                <i class="bi bi-arrow-clockwise me-1"></i>Retry
                            </button>
                        </div>
                    `;
                });
            
            // Send message
            chatForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                const text = messageInput.value.trim();
                if (!text && !uploadedImageUrl) return;
                
                sendBtn.disabled = true;
                const originalBtnHtml = sendBtn.innerHTML;
                sendBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
                
                try {
                    await connection.invoke("SendCommunityMessage", currentDisplayName, text, uploadedImageUrl);
                    messageInput.value = '';
                    messageInput.style.height = 'auto';
                    uploadedImageUrl = null;
                    imageInput.value = '';
                    imagePreviewContainer.style.display = 'none';
                } catch (err) {
                    console.error('Send error:', err);
                    alert('Failed to send message. Please try again.');
                } finally {
                    sendBtn.disabled = false;
                    sendBtn.innerHTML = originalBtnHtml;
                    messageInput.focus();
                }
            });
            
            // Enter to send
            messageInput.addEventListener('keydown', (e) => {
                if (e.key === 'Enter' && !e.shiftKey) {
                    e.preventDefault();
                    chatForm.dispatchEvent(new Event('submit'));
                }
            });
            
            // Leave chat on unload
            window.addEventListener('beforeunload', () => {
                connection.invoke("LeaveCommunityChat").catch(() => {});
            });
            
        } else {
            // Non-logged in view
            document.getElementById('chat-messages').innerHTML = `
                <div class="empty-state">
                    <i class="bi bi-chat-square-heart"></i>
                    <h5 style="color: var(--text-primary);">Join the Conversation</h5>
                    <p style="color: var(--text-muted);">Login to see messages and chat with the community</p>
                </div>
            `;
            document.getElementById('connection-status').innerHTML = '<i class="bi bi-eye me-1"></i>View Only';
            document.getElementById('connection-status').className = 'badge bg-secondary';
        }
    </script>
}
